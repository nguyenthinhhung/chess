{
  "manifest_version": 3,
  "name": "Chess.com to Lichess Analyzer",
  "version": "0.4.0",
  "description": "Import chess.com games into Lichess for analysis, plus an opening coach for the Italian and Caro-Kann.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.chess.com/*",
    "https://lichess.org/*",
    "https://api.chess.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.chess.com/*"],
      "js": ["pgn.js", "chesscore.js", "repertoire.js", "coach.js", "content.js", "coach-ui.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.chess.com/*"],
      "js": ["coach-bridge.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze on Lichess",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html"
}
