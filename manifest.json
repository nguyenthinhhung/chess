{
  "manifest_version": 3,
  "name": "Chess.com to Lichess Analyzer",
  "version": "0.4.0",
  "description": "Import chess.com games into Lichess for analysis, plus an in-game Stockfish coach with opening recognition (vs bots and on the analysis board).",
  "permissions": ["storage", "offscreen"],
  "host_permissions": [
    "https://*.chess.com/*",
    "https://lichess.org/*",
    "https://api.chess.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.chess.com/*"],
      "js": ["pgn.js", "chesscore.js", "explain.js", "content.js", "chess-coach.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.chess.com/*"],
      "js": ["chess-coach-bridge.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/stockfish-18-lite-single.js",
        "vendor/stockfish-18-lite-single.wasm",
        "openings.json"
      ],
      "matches": ["https://*.chess.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze on Lichess",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html"
}
